# Cơ sở dữ liệu cho local hoặc Azure Database for PostgreSQL
POSTGRES_DB=airticket
POSTGRES_USER=postgres
POSTGRES_PASSWORD=doi-mat-khau-database

# API khi chạy local hoặc production
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/airticket
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=doi-mat-khau-database
SPRING_FLYWAY_ENABLED=true
APP_AUTH_JWT_SECRET=doi-secret-toi-thieu-32-ky-tu-va-phai-thay-doi
APP_AUTH_JWT_ISSUER=airticket-api
APP_AUTH_JWT_ACCESS_TOKEN_TTL_SECONDS=900
APP_AUTH_JWT_REFRESH_TOKEN_TTL_SECONDS=2592000

# để trống nếu chạy local
APP_AUTH_OAUTH_FRONTEND_CALLBACK_URL=#https://airplane.id.vn/oauth/callback
APP_AUTH_OAUTH_STATE_TTL_SECONDS=300
APP_AUTH_OAUTH_EXCHANGE_CODE_TTL_SECONDS=180
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
#Để trống nếu chạy local
GOOGLE_OAUTH_REDIRECT_URI=#https://api.airplane.id.vn/api/auth/oauth/google/callback

# Production mặc định dùng domain airplane.id.vn.
# Nếu chạy local, đổi tạm thành http://localhost:3000,http://127.0.0.1:3000
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://airplane.id.vn,https://www.airplane.id.vn
APP_UPLOAD_AVATAR_DIR=uploads/avatars

# Cấu hình gửi mail
# Local có thể để APP_MAIL_ENABLED=false nếu chưa cần gửi thật.
# Production phải bật true và điền đủ SPRING_MAIL_* + APP_MAIL_FROM_EMAIL.
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_CONNECTION_TIMEOUT=5000
SPRING_MAIL_TIMEOUT=5000
SPRING_MAIL_WRITE_TIMEOUT=5000
APP_MAIL_ENABLED=false
APP_MAIL_FROM_EMAIL=

# Thanh toán SePay
# Khi thiếu APP_PAYMENT_SEPAY_TOKEN hoặc APP_PAYMENT_SEPAY_BANK_ACCOUNT_ID,
# hệ thống sẽ rơi về sessionMode=local.
# APP_PAYMENT_SEPAY_BANK_ACCOUNT_ID phải là UUID tài khoản ngân hàng SePay API v2.
# APP_PAYMENT_SEPAY_WEBHOOK_API_KEY chỉ dùng để xác thực webhook SePay,
# không quyết định việc tạo session live.
# Luồng tạo đơn hàng live hiện ưu tiên API v2.
# Nếu ngân hàng chưa hỗ trợ tạo đơn hàng API v2, hệ thống sẽ dùng QR chuyển khoản SePay.
# Có thể dùng bộ biến APP_PAYMENT_SEPAY_* hoặc bộ biến SEPAY_* để tương thích cấu hình cũ.
# Webhook public thật vẫn cần trỏ về
# https://api.airplane.id.vn/api/payments/webhooks/sepay để đối soát giao dịch tự động.
APP_PAYMENT_SEPAY_TOKEN=
APP_PAYMENT_SEPAY_BANK_ACCOUNT_ID=
APP_PAYMENT_SEPAY_WEBHOOK_API_KEY=
APP_PAYMENT_SEPAY_BANK_NAME=BIDV
APP_PAYMENT_SEPAY_ACCOUNT_NUMBER=
APP_PAYMENT_SEPAY_ACCOUNT_HOLDER_NAME=
APP_PAYMENT_SEPAY_ORDER_DURATION_SECONDS=900
APP_PAYMENT_SEPAY_API_BASE_URL=https://userapi.sepay.vn/v2
APP_PAYMENT_SEPAY_QR_BASE_URL=https://qr.sepay.vn/img

SEPAY_API_TOKEN=
SEPAY_BANK_ACCOUNT_UUID=
SEPAY_WEBHOOK_API_KEY=
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_NAME=
SEPAY_ORDER_DURATION_SECONDS=
SEPAY_API_BASE_URL=https://userapi.sepay.vn/v2
SEPAY_QR_BASE_URL=https://qr.sepay.vn/img

# Web
# Production dùng api.airplane.id.vn. Khi chạy local có thể đổi tạm thành http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=https://api.airplane.id.vn
WEB_PORT=3000
API_PORT=8080

# Trợ lý AI và nguồn dữ liệu phụ trợ
# Chỉ cần khai báo một trong hai khóa Gemini.
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENWEATHER_API_KEY=
OPEN_WEATHER_API_KEY=
NEWSDATA_API_KEY=
NEWSDATAIO_API_KEY=

# Dịch vụ phụ trợ khác
# Các biến này chỉ điền khi môi trường của bạn thực sự dùng Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
